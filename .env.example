# Neon Postgres — get from https://neon.tech
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Secret API key — run: openssl rand -hex 32
CRM_API_KEY=your-secret-key-here

# Resend — get from https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx

# Public vars (used by browser dashboard)
NEXT_PUBLIC_CRM_URL=https://your-crm.vercel.app
NEXT_PUBLIC_CRM_API_KEY=your-secret-key-here
